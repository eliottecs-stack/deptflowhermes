{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeptFlow local secret contract",
  "type": "object",
  "required": ["BEREACH_API_KEY"],
  "properties": {
    "BEREACH_API_KEY": { "type": "string", "description": "BeReach API key for the client LinkedIn account." },
    "OPENAI_API_KEY": { "type": "string", "description": "Default LLM provider key." },
    "GOOGLE_SERVICE_ACCOUNT_JSON": { "type": "string", "description": "Service account JSON, stored in the local encrypted vault." },
    "GOOGLE_SHEET_ID": { "type": "string", "description": "Target CRM spreadsheet id." }
  }
}
